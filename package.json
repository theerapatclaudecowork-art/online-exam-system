{
  "name": "exam-system",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "gas:push": "cp Code.gs gas/Code.gs && cd gas && clasp push --force",
    "gas:deploy": "npm run gas:push && cd gas && clasp deploy --description \"v$(node -p \"require('./package.json').version\")\"",
    "gas:open": "cd gas && clasp open",
    "deploy": "npm run build && gh-pages -d dist"
  },
  "dependencies": {
    "canvas-confetti": "^1.9.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sweetalert2": "^11.10.8"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "gh-pages": "^6.3.0",
    "postcss": "^8.4.39",
    "tailwindcss": "^3.4.7",
    "vite": "^5.4.0"
  }
}
